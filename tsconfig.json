{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "skipLibCheck": true, // 跳过所有 node_modules 里的 .d.ts 类型检查
    "skipDefaultLibCheck": true, // 跳过 TS 内置库类型检查（如 lib.dom.d.ts）
    "strict": false, // 开启所有严格类型检查规则
    "jsx": "preserve",
    "esModuleInterop": true, // 解决 ES Modules 和 CommonJS 模块的互操作性问题
    "sourceMap": true,
    "importHelpers": true, // 从 tslib 库复用辅助函数
    "allowSyntheticDefaultImports": true, // 允许「合成默认导入」
    "useDefineForClassFields": true, // 遵循 ESNext 类字段规范
    "resolveJsonModule": true, // 允许 TS 直接导入 JSON 文件（如 import config from './config.json'），并自动生成 JSON 的类型提示。
    "moduleResolution": "node", // 使用 Node.js 的模块解析策略
    "lib": [
      "esnext",
      "dom"
    ],
    "paths": {
      "@/*": ["src/*"]
    },
    "allowJs": true,
    "types": ["miniprogram-api-typings", "@dcloudio/types", "node"],
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "src/**/*.js",
    "async-import.d.ts",
    "async-component.d.ts",
    "shims-uni.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "unpackage",
    "src/**/*.nvue",
    "**/node_modules/*"
  ]
}